# Copia este archivo a .env.local y rellena los valores.
# NUNCA hagas commit de .env.local.

# ============================================
# Firebase Admin (server-side, NUNCA público)
# ============================================
# Opción A (recomendada en Vercel): JSON del service account en base64 de una sola línea.
#   base64 -i clave.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Opción B: campos sueltos. FIREBASE_PRIVATE_KEY debe ser una sola línea con \n.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Bucket de Storage para el Admin SDK (subida de ecos, etc.).
FIREBASE_STORAGE_BUCKET=

# Alias alternativos (algunos scripts/legacy usan estos nombres en lugar de FIREBASE_*).
# FIREBASE_ADMIN_PROJECT_ID=
# FIREBASE_ADMIN_CLIENT_EMAIL=
# FIREBASE_ADMIN_PRIVATE_KEY=

# ============================================
# Firebase Client (NEXT_PUBLIC_*, visible al navegador)
# ============================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ============================================
# Sentry — monitoreo de errores
# ============================================
# DSN público del proyecto. Sin esto, Sentry queda inactivo en cliente/server/edge.
NEXT_PUBLIC_SENTRY_DSN=

# ============================================
# Turnstile — CAPTCHA (Cloudflare)
# ============================================
# Sin TURNSTILE_SECRET_KEY no verifica.
# Con secret + TURNSTILE_ENFORCE=true exige token válido del widget.
TURNSTILE_SECRET_KEY=
TURNSTILE_ENFORCE=false

# ============================================
# Rate limiting — Upstash Redis
# ============================================
# Recomendado en producción. Si faltan, el código cae a un fallback en memoria.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================
# Resend — emails transaccionales
# ============================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=hola@almamundi.org
MAIL_FROM=AlmaMundi <hola@almamundi.org>
# Bandeja interna para /api/privacy-data-request (opcional; default: hola@almamundi.org).
PRIVACY_DATA_REQUEST_TO=

# ============================================
# Configuración general
# ============================================
# URL canónica (metadata, OG, favicons absolutos).
NEXT_PUBLIC_SITE_URL=https://www.almamundi.org
NEXT_PUBLIC_APP_URL=https://www.almamundi.org
PUBLIC_SITE_URL=https://www.almamundi.org

# ============================================
# Servicios externos (opcionales)
# ============================================
# Análisis IA en /api/submit (Whisper + GPT-4o-mini). Sin esto se usa huella por defecto.
OPENAI_API_KEY=
# Noticias en vivo (/api/news). Registro gratis en newsdata.io / gnews.io.
NEWSDATA_API_KEY=
GNEWS_API_KEY=
# Detalle de health interno (no público).
INTERNAL_HEALTH_SECRET=

# ============================================
# Demo / desarrollo
# ============================================
# Solo el string exacto "true" muestra historias demo. En prod debe ser false u omitirse.
NEXT_PUBLIC_SHOW_DEMO_STORIES=false
