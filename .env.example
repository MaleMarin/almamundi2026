# Copia a .env.local y rellena los valores.
# Nunca hagas commit de .env.local.

# === Firebase cliente (NEXT_PUBLIC_* se expone al navegador) ===
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# === Firebase Admin (solo servidor) ===
# Opción A: JSON en base64 (recomendado)
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Opción B: Campos sueltos (+ bucket para Storage Admin)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# Alternativos (algunos scripts usan estos nombres)
# FIREBASE_ADMIN_PROJECT_ID=
# FIREBASE_ADMIN_CLIENT_EMAIL=
# FIREBASE_ADMIN_PRIVATE_KEY=

# === App ===
# URL canónica (metadata, favicon/Open Graph absolutos). En Vercel: https://almamundi.org
NEXT_PUBLIC_SITE_URL=https://almamundi.org
NEXT_PUBLIC_APP_URL=https://almamundi.org
PUBLIC_SITE_URL=https://www.almamundi.org

# === Resend (emails) ===
RESEND_API_KEY=
RESEND_FROM_EMAIL=hola@almamundi.org
MAIL_FROM=AlmaMundi <hola@almamundi.org>

# === Admin / Curaduría ===
# Publicación y listados usan Firebase Auth (Bearer ID token) + allowlist en lib/adminEmails.ts.
# Ya no se usa ADMIN_PUBLISH_TOKEN ni x-admin-token.

# === Rate limiting (recomendado en producción) ===
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === Cloudflare Turnstile (opcional) ===
# Tras añadir el widget en el cliente y enviar el token, pon TURNSTILE_ENFORCE=true.
TURNSTILE_SECRET_KEY=
TURNSTILE_ENFORCE=

# === Health interno (detalle bucket/Firestore; no público) ===
INTERNAL_HEALTH_SECRET=

# === Huella visual (análisis IA en backend) ===
# Si está definida, POST /api/submit usa Whisper (audio/video) + GPT-4o-mini para análisis semántico
# y devuelve parámetros visuales de la huella; sin ella se usa huella por defecto desde seed.
OPENAI_API_KEY=

# === Noticias en vivo (API /api/news) ===
# Regístrate gratis en newsdata.io o gnews.io para obtener una key.
NEWSDATA_API_KEY=
GNEWS_API_KEY=
